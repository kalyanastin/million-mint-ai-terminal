{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "mcp-studio",
  "version": "0.1.0",
  "identifier": "com.mcpstudio.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MCP Studio",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "allow": [
        { "name": "node", "cmd": "node", "args": true },
        { "name": "npx", "cmd": "npx", "args": true },
        { "name": "npm", "cmd": "npm", "args": true },
        { "name": "python", "cmd": "python", "args": true },
        { "name": "pip", "cmd": "pip", "args": true }
      ]
    }
  }
}
