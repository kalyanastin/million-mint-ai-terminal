# ============================================================
# Million Mint AI Terminal — Environment Variables Template
# ============================================================
# Copy this file to .env in each subdirectory and fill in values.

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- CoinGecko (Worker) ---
COINGECKO_API_KEY=           # Optional: Demo API key from coingecko.com
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
POLL_INTERVAL_SECONDS=60

# --- Gemini AI (Backend) ---
GEMINI_API_KEY=              # Required: From ai.google.dev

# --- Backend ---
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Supabase Waitlist ---
NEXT_PUBLIC_SUPABASE_URL=            # Optional/Required for Production Waitlist: https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # Optional/Required for Production Waitlist: Your anon key

